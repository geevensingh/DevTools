<Application x:Class="CopilotSessionMonitor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:CopilotSessionMonitor.Views">
    <Application.Resources>
        <ResourceDictionary>
            <conv:BoolToVisibilityConverter x:Key="BoolToVisible"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisible"/>
            <conv:NonEmptyToVisibilityConverter x:Key="NonEmptyToVisible"/>

            <!-- Fluent dark palette -->
            <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#FF2B2D31" />
            <SolidColorBrush x:Key="WindowBackgroundOpaqueBrush" Color="#FF24262A" />
            <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FF2B2D31" />
            <SolidColorBrush x:Key="RowBackgroundBrush" Color="#FF2F3136" />
            <SolidColorBrush x:Key="RowHoverBrush" Color="#FF383A40" />
            <SolidColorBrush x:Key="BorderBrush" Color="#FF3A3C41" />
            <SolidColorBrush x:Key="TextBrush" Color="#FFE8E8EC" />
            <SolidColorBrush x:Key="TextDimBrush" Color="#FFA8A9AD" />
            <SolidColorBrush x:Key="TextMuteBrush" Color="#FF7A7B80" />
            <SolidColorBrush x:Key="AccentBrush" Color="#FF4CC2FF" />

            <SolidColorBrush x:Key="StateRedBrush" Color="#FFE74856" />
            <SolidColorBrush x:Key="StateBlueBrush" Color="#FF4CC2FF" />
            <SolidColorBrush x:Key="StateYellowBrush" Color="#FFF7C331" />
            <SolidColorBrush x:Key="StateGreenBrush" Color="#FF6CCB5F" />
            <SolidColorBrush x:Key="StateGrayBrush" Color="#FF6E7177" />

            <Style x:Key="WindowTitleText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
