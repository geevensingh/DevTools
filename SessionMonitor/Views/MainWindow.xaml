<Window x:Class="CopilotSessionMonitor.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CopilotSessionMonitor.ViewModels"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Copilot CLI Sessions"
        Width="540" Height="640"
        MinWidth="380" MinHeight="220"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBackgroundOpaqueBrush}"
        ShowInTaskbar="False"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="13"
        Foreground="{StaticResource TextBrush}">

    <Window.InputBindings>
        <!-- KeyBindings populated in code-behind so they can call into the view's
             own private FocusFilterBox method. -->
    </Window.InputBindings>

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="38"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="6"
            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <!-- Action button -->
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#1FFFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#1FFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Title-bar control button -->
        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1FFFFFFF"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFC42B1C"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PinnedButton" TargetType="Button" BasedOn="{StaticResource ChromeButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="Background" Value="#1F4CC2FF"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Toggle pill -->
        <Style x:Key="TogglePill" TargetType="ToggleButton">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="28" Height="16" CornerRadius="8" Background="#FF4A4C52" x:Name="Track" Margin="0,0,6,0">
                                <Ellipse x:Name="Thumb" Width="12" Height="12" HorizontalAlignment="Left" Margin="2,0,0,0" Fill="{StaticResource TextDimBrush}"/>
                            </Border>
                            <ContentPresenter VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter TargetName="Thumb" Property="Fill" Value="White"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Session row -->
        <DataTemplate DataType="{x:Type vm:SessionRowViewModel}">
            <Border x:Name="RowRoot" Padding="14,12" BorderBrush="#0DFFFFFF" BorderThickness="0,0,0,1" Background="Transparent" Cursor="Hand">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                <Setter Property="Background" Value="#0F4CC2FF"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#0AFFFFFF"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleExpandedCommand}"/>
                </Border.InputBindings>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Ellipse Grid.RowSpan="2" Width="12" Height="12" Margin="0,4,0,0" VerticalAlignment="Top"
                             Fill="{Binding StatusBrush}">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAttention}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard Name="AttentionPulse">
                                                <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1.0" To="0.45" Duration="0:0:0.9"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                        <DataTrigger.ExitActions>
                                            <StopStoryboard BeginStoryboardName="AttentionPulse"/>
                                        </DataTrigger.ExitActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>

                    <TextBlock Grid.Column="1" Text="{Binding DisplayTitle}" FontWeight="SemiBold" FontSize="13.5"
                               TextTrimming="CharacterEllipsis" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0"/>
                    <TextBlock Grid.Column="2" Grid.RowSpan="2" Text="{Binding WhenText}" Foreground="{StaticResource TextMuteBrush}"
                               FontSize="11" VerticalAlignment="Center" Margin="10,0,0,0"/>

                    <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Margin="10,2,0,0">
                        <TextBlock Text="{Binding Repository}" Foreground="{StaticResource TextDimBrush}" FontSize="11.5"/>
                        <TextBlock Text="  ·  " Foreground="{StaticResource TextMuteBrush}" FontSize="11.5" Visibility="{Binding Branch, Converter={StaticResource NonEmptyToVisible}}"/>
                        <Border Background="#15FFFFFF" CornerRadius="8" Padding="6,1" Margin="0,0,8,0" Visibility="{Binding Branch, Converter={StaticResource NonEmptyToVisible}}">
                            <TextBlock Text="{Binding Branch}" Foreground="{StaticResource TextDimBrush}" FontSize="10.5"/>
                        </Border>
                        <TextBlock Text="  ·  " Foreground="{StaticResource TextMuteBrush}" FontSize="11.5"/>
                        <TextBlock Text="{Binding StatusLine}" Foreground="{Binding StatusBrush}" FontSize="11.5"
                                   TextTrimming="CharacterEllipsis" MaxWidth="280"/>
                        <TextBlock Text="{Binding TimeInStateText}" Foreground="{StaticResource TextMuteBrush}" FontSize="11" Margin="6,0,0,0"
                                   Visibility="{Binding TimeInStateText, Converter={StaticResource NonEmptyToVisible}}"/>
                    </StackPanel>

                    <!-- Expanded actions -->
                    <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Vertical" Margin="10,8,0,0"
                                Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisible}}">
                        <WrapPanel>
                            <Button Style="{StaticResource ActionButton}" Margin="0,0,6,6" Content="🪟 Focus terminal" Command="{Binding FocusTerminalCommand}"/>
                            <Button Style="{StaticResource ActionButton}" Margin="0,0,6,6" Content="📋 Copy session id" Command="{Binding CopySessionIdCommand}"/>
                            <Button Style="{StaticResource ActionButton}" Margin="0,0,6,6" Content="📝 Open repo in VS Code" Command="{Binding OpenInVsCodeCommand}"/>
                            <Button Style="{StaticResource ActionButton}" Margin="0,0,6,6" Content="📂 Open session state" Command="{Binding OpenSessionStateCommand}" ToolTip="Open the session-state folder in VS Code (events.jsonl, workspace.yaml, etc.)"/>
                            <Button Style="{StaticResource ActionButton}" Margin="0,0,6,6" Content="📁 Reveal folder" Command="{Binding RevealInExplorerCommand}" ToolTip="Open the session's working directory in File Explorer"/>
                            <Button Style="{StaticResource ActionButton}" Margin="0,0,6,6" Content="{Binding MuteIcon}" Command="{Binding ToggleMuteCommand}" ToolTip="{Binding MuteTooltip}"/>
                            <Button Style="{StaticResource ActionButton}" Margin="0,0,6,6" Content="{Binding KillLabel}" Command="{Binding KillProcessCommand}"/>
                        </WrapPanel>
                        <Border Background="#40000000" BorderBrush="#0DFFFFFF" BorderThickness="1" CornerRadius="5" Padding="9,7" Margin="0,2,8,0"
                                Visibility="{Binding PreviewBlock, Converter={StaticResource NonEmptyToVisible}}">
                            <TextBlock Text="{Binding PreviewBlock}" Foreground="{StaticResource TextDimBrush}" FontFamily="Cascadia Mono, Consolas" FontSize="11"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Tokens summary -->
                        <TextBlock Text="{Binding TokensText}" Foreground="{StaticResource TextMuteBrush}" FontSize="11" Margin="0,4,0,0"
                                   Visibility="{Binding TokensText, Converter={StaticResource NonEmptyToVisible}}"/>

                        <!-- Recent-events timeline: collapsed by default. Click the affordance to expand. -->
                        <Button Command="{Binding ToggleTimelineCommand}" Margin="0,8,0,0"
                                HorizontalAlignment="Left" Background="Transparent" BorderThickness="0"
                                Padding="0" Cursor="Hand" Foreground="{StaticResource TextDimBrush}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="3" Padding="2,1">
                                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                            <TextBlock Text="{Binding TimelineToggleLabel}" FontSize="11" Foreground="{StaticResource TextDimBrush}"/>
                        </Button>

                        <ItemsControl ItemsSource="{Binding Timeline}" Margin="0,4,8,0"
                                      Visibility="{Binding IsTimelineExpanded, Converter={StaticResource BoolToVisible}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1" ToolTip="{Binding Text}" Cursor="Hand">
                                        <Grid.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.CopyTimelineEntryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          CommandParameter="{Binding Text}"/>
                                        </Grid.InputBindings>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="22"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding TimeText}" Foreground="{StaticResource TextMuteBrush}" FontSize="10.5" FontFamily="Cascadia Mono, Consolas"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Glyph}" FontSize="11" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Text}" Foreground="{StaticResource TextDimBrush}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Border Background="{StaticResource WindowBackgroundOpaqueBrush}" BorderBrush="#20FFFFFF" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" BorderBrush="#0FFFFFFF" BorderThickness="0,0,0,1" Background="Transparent">
                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="14,0" VerticalAlignment="Center"
                                shell:WindowChrome.IsHitTestVisibleInChrome="False">
                        <Border Width="14" Height="14" CornerRadius="3">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF4CC2FF" Offset="0"/>
                                    <GradientStop Color="#FF6CCB5F" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <TextBlock Text="Copilot CLI Sessions" Style="{StaticResource WindowTitleText}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button Style="{StaticResource PinnedButton}" Command="{Binding TogglePinCommand}" ToolTip="Pin (always on top)" Content="📌"/>
                        <Button Style="{StaticResource ChromeButton}" Click="Settings_Click" ToolTip="Settings" Content="⚙"/>
                        <Button Style="{StaticResource ChromeButton}" Click="Minimize_Click" ToolTip="Hide" Content="─"/>
                        <Button Style="{StaticResource CloseButton}" Click="Hide_Click" ToolTip="Close" Content="✕"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Toolbar -->
            <Border Grid.Row="1" Padding="14,10" BorderBrush="#0FFFFFFF" BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <ToggleButton Style="{StaticResource TogglePill}" IsChecked="{Binding ShowOffline, Mode=TwoWay}">
                            <TextBlock Text="Show offline" FontSize="12" Foreground="{StaticResource TextDimBrush}"/>
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource TogglePill}" IsChecked="{Binding GroupByRepo, Mode=TwoWay}" Margin="14,0,0,0">
                            <TextBlock Text="Group by repo" FontSize="12" Foreground="{StaticResource TextDimBrush}"/>
                        </ToggleButton>
                    </StackPanel>

                    <!-- Search box -->
                    <Border Grid.Column="1" Margin="14,0" Background="#1FFFFFFF" BorderBrush="#1FFFFFFF" BorderThickness="1" CornerRadius="5">
                        <Border.Resources>
                            <Style x:Key="SearchBoxStyle" TargetType="TextBox">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
                                <Setter Property="VerticalContentAlignment" Value="Center"/>
                                <Setter Property="Padding" Value="8,4,30,4"/>
                                <Setter Property="FontSize" Value="12"/>
                            </Style>
                        </Border.Resources>
                        <Grid>
                            <TextBox x:Name="FilterBox" Style="{StaticResource SearchBoxStyle}"
                                     Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                                     ToolTip="Filter sessions (Ctrl+F to focus, Esc to clear)"
                                     KeyDown="FilterBox_KeyDown"/>
                            <TextBlock IsHitTestVisible="False" Text="Filter sessions… (Ctrl+F)"
                                       Foreground="{StaticResource TextMuteBrush}"
                                       VerticalAlignment="Center" Margin="9,0,0,0" FontSize="12"
                                       Visibility="{Binding IsFilterEmpty, Converter={StaticResource BoolToVisible}}"/>
                            <Button Width="22" Height="22" HorizontalAlignment="Right" VerticalAlignment="Center"
                                    Margin="0,0,4,0" Background="Transparent" BorderThickness="0"
                                    Foreground="{StaticResource TextMuteBrush}"
                                    Cursor="Hand" Content="✕" FontSize="11"
                                    ToolTip="Clear filter (Esc)"
                                    Command="{Binding ClearFilterCommand}"
                                    Visibility="{Binding IsFilterEmpty, Converter={StaticResource InverseBoolToVisible}}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <TextBlock Grid.Column="2" Text="{Binding SummaryText}" VerticalAlignment="Center"
                               Foreground="{StaticResource TextMuteBrush}" FontSize="11.5"/>
                </Grid>
            </Border>

            <!-- Session list with overlaid "no matches" placeholder -->
            <Grid Grid.Row="2">
                <ListBox x:Name="SessionsList" Background="Transparent" BorderThickness="0"
                         ItemsSource="{Binding SessionsView}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         HorizontalContentAlignment="Stretch"
                         KeyDown="SessionsList_KeyDown"
                         Foreground="{StaticResource TextBrush}">
                    <ListBox.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.ContainerStyle>
                                <Style TargetType="GroupItem">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="GroupItem">
                                                <Expander IsExpanded="True" Background="Transparent" Foreground="{StaticResource TextBrush}" Padding="0">
                                                    <Expander.Header>
                                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="11.5" Foreground="{StaticResource TextDimBrush}"/>
                                                            <TextBlock Margin="6,0,0,0" Foreground="{StaticResource TextMuteBrush}" FontSize="11" VerticalAlignment="Center">
                                                                <Run Text="("/><Run Text="{Binding ItemCount, Mode=OneWay}"/><Run Text=")"/>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Expander.Header>
                                                    <ItemsPresenter/>
                                                </Expander>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </GroupStyle.ContainerStyle>
                        </GroupStyle>
                    </ListBox.GroupStyle>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{StaticResource TextMuteBrush}" FontSize="12" Opacity="0.85"
                           Visibility="{Binding HasNoVisibleRows, Converter={StaticResource BoolToVisible}}">
                    No sessions match your search.
                </TextBlock>
            </Grid>

            <!-- Footer -->
            <Border Grid.Row="3" Padding="14,8" BorderBrush="#0FFFFFFF" BorderThickness="0,1,0,0">
                <StackPanel>
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource StateRedBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="change" Margin="4,0,0,0" Foreground="{StaticResource TextMuteBrush}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource StateBlueBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="needs me" Margin="4,0,0,0" Foreground="{StaticResource TextMuteBrush}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource StateYellowBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="planning" Margin="4,0,0,0" Foreground="{StaticResource TextMuteBrush}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource StateGreenBrush}" VerticalAlignment="Center"/>
                                <TextBlock Text="idle" Margin="4,0,0,0" Foreground="{StaticResource TextMuteBrush}" FontSize="11" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="{Binding LegendCount}" HorizontalAlignment="Right" Foreground="{StaticResource TextMuteBrush}" FontSize="11" VerticalAlignment="Center"/>
                    </Grid>
                    <TextBlock Text="{Binding StatsText}" Foreground="{StaticResource TextMuteBrush}" FontSize="10.5" Margin="0,4,0,0" Opacity="0.85"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
