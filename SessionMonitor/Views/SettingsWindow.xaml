<Window x:Class="CopilotSessionMonitor.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Settings"
        Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource WindowBackgroundOpaqueBrush}"
        Foreground="{StaticResource TextBrush}"
        FontFamily="Segoe UI Variable, Segoe UI"
        FontSize="13"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome
            CaptionHeight="38"
            CornerRadius="0"
            GlassFrameThickness="0"
            ResizeBorderThickness="0"
            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1FFFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="CaretBrush" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#1FFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuteBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,12,0,6"/>
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>
        <Style x:Key="HelpText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuteBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="MinWidth" Value="80"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Background" Value="#1FFFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="#1FFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#FF071A26"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource WindowBackgroundOpaqueBrush}" BorderBrush="#20FFFFFF" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title bar (matches MainWindow chrome) -->
            <Border Grid.Row="0" BorderBrush="#0FFFFFFF" BorderThickness="0,0,0,1" Background="Transparent">
                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="14,0" VerticalAlignment="Center"
                                shell:WindowChrome.IsHitTestVisibleInChrome="False">
                        <Border Width="14" Height="14" CornerRadius="3">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#FF4CC2FF" Offset="0"/>
                                    <GradientStop Color="#FF6CCB5F" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <TextBlock Text="Settings" Style="{StaticResource WindowTitleText}" Margin="8,0,0,0" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,4,0"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                        <Button x:Name="CloseButton" Click="Cancel_Click" ToolTip="Close" Content="✕">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextDimBrush}"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Width" Value="36"/>
                                    <Setter Property="Height" Value="28"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#FFC42B1C"/>
                                                        <Setter Property="Foreground" Value="White"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Body -->
            <StackPanel Grid.Row="1" Margin="20,12,20,20">
                <TextBlock Style="{StaticResource HelpText}">
                    Stored in <Run FontFamily="Cascadia Mono, Consolas" Foreground="{StaticResource TextDimBrush}" Text="%LOCALAPPDATA%\CopilotSessionMonitor\settings.json"/>.
                </TextBlock>

                <!-- Refresh / staleness -->
                <TextBlock Text="REFRESH" Style="{StaticResource SectionHeader}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Heartbeat interval (seconds)" Style="{StaticResource FieldLabel}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="HeartbeatBox" Width="80"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource HelpText}"
                               Text="How often to repoll PIDs and git status. Real-time event activity is caught regardless via a file watcher; lower values mostly speed up offline detection. Min 1, max 60."/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Stale threshold (hours)" Style="{StaticResource FieldLabel}" Margin="0,12,12,0"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="StaleHoursBox" Width="80" Margin="0,12,0,0"/>
                    <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource HelpText}"
                               Text="An alive session that hasn't fired any events for this long is treated as Offline. Active sessions (in-flight turn or tool) are exempt. Min 1, max 168 (1 week)."/>
                </Grid>

                <!-- Notifications -->
                <TextBlock Text="NOTIFICATIONS" Style="{StaticResource SectionHeader}"/>
                <CheckBox x:Name="NotifyBlueBox" Content="Show toast when a session is waiting on me (Blue)"/>
                <CheckBox x:Name="NotifyRedToGreenBox" Content="Show toast when a session finishes its changes (Red → Green)"/>

                <!-- Sounds -->
                <TextBlock Text="SOUNDS" Style="{StaticResource SectionHeader}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Blue (waiting on me)" Style="{StaticResource FieldLabel}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" x:Name="BlueSoundBox" Width="140" Margin="0,0,6,0"/>
                    <Button Grid.Row="0" Grid.Column="2" Content="▶" Width="28" Click="PreviewBlue_Click" Style="{StaticResource DialogButton}" Padding="0" ToolTip="Preview"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Red → Green (changes finished)" Style="{StaticResource FieldLabel}" Margin="0,8,12,0"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="GreenSoundBox" Width="140" Margin="0,8,6,0"/>
                    <Button Grid.Row="1" Grid.Column="2" Content="▶" Width="28" Margin="0,8,0,0" Click="PreviewGreen_Click" Style="{StaticResource DialogButton}" Padding="0" ToolTip="Preview"/>
                </Grid>

                <!-- Buttons -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Style="{StaticResource DialogButton}" Content="Cancel" Click="Cancel_Click" IsCancel="True"/>
                    <Button Style="{StaticResource PrimaryButton}" Content="Save" Click="Save_Click" IsDefault="True"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
