<Window x:Class="DiffViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DiffViewer.ViewModels"
        xmlns:views="clr-namespace:DiffViewer.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        mc:Ignorable="d"
        Title="{Binding WindowTitle, FallbackValue=DiffViewer}"
        Icon="/Assets/diffviewer.ico"
        Width="1200"
        Height="800"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="OnPreviewKeyDown">
    <Window.InputBindings>
        <!-- Settings -->
        <KeyBinding Key="OemComma" Modifiers="Control" Command="{Binding ShowSettingsCommand}"/>

        <!-- Refresh -->
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>

        <!-- Hunk navigation: F8 next change, F7 previous change.
             Cross-file + cross-section flow with cycling. Alt+Down /
             Alt+Up are screen-reader-friendly aliases (NVDA claims F7,
             JAWS occasionally F8). -->
        <KeyBinding Key="F8"   Command="{Binding NavigateNextChangeCommand}"/>
        <KeyBinding Key="F7"   Command="{Binding NavigatePreviousChangeCommand}"/>
        <KeyBinding Key="Down" Modifiers="Alt" Command="{Binding NavigateNextChangeCommand}"/>
        <KeyBinding Key="Up"   Modifiers="Alt" Command="{Binding NavigatePreviousChangeCommand}"/>

        <!-- File-step (skip per-hunk) -->
        <KeyBinding Key="F8" Modifiers="Shift" Command="{Binding NavigateNextFileCommand}"/>
        <KeyBinding Key="F7" Modifiers="Shift" Command="{Binding NavigatePreviousFileCommand}"/>

        <!-- Section-step -->
        <KeyBinding Key="F8" Modifiers="Control" Command="{Binding NavigateNextSectionCommand}"/>
        <KeyBinding Key="F7" Modifiers="Control" Command="{Binding NavigatePreviousSectionCommand}"/>

        <!-- Toolbar toggles -->
        <KeyBinding Key="W" Modifiers="Control"        Command="{Binding ToggleIgnoreWhitespaceCommand}"/>
        <KeyBinding Key="W" Modifiers="Control+Shift"  Command="{Binding ToggleVisibleWhitespaceCommand}"/>
        <KeyBinding Key="I" Modifiers="Control"        Command="{Binding ToggleSideBySideCommand}"/>
        <KeyBinding Key="D" Modifiers="Control"        Command="{Binding ToggleIntraLineDiffCommand}"/>
        <KeyBinding Key="L" Modifiers="Control"        Command="{Binding ToggleLiveUpdatesCommand}"/>

        <!-- Display modes -->
        <KeyBinding Key="D1" Modifiers="Control" Command="{Binding SetDisplayModeFullPathCommand}"/>
        <KeyBinding Key="D2" Modifiers="Control" Command="{Binding SetDisplayModeRepoRelativeCommand}"/>
        <KeyBinding Key="D3" Modifiers="Control" Command="{Binding SetDisplayModeGroupedCommand}"/>

        <!-- Focus cycle -->
        <KeyBinding Key="F6" Command="{Binding CycleFocusCommand}"/>

        <!-- Zoom (forwarded to DiffPane). Ctrl+= covers ANSI '+' (unshifted),
             Ctrl+OemPlus covers shifted layouts where OEM gives the actual
             '+' keycode, Ctrl+Add covers the numeric keypad. Same triple
             for zoom-out. -->
        <KeyBinding Key="OemPlus"  Modifiers="Control" Command="{Binding DiffPane.ZoomInCommand}"/>
        <KeyBinding Key="Add"      Modifiers="Control" Command="{Binding DiffPane.ZoomInCommand}"/>
        <KeyBinding Key="OemMinus" Modifiers="Control" Command="{Binding DiffPane.ZoomOutCommand}"/>
        <KeyBinding Key="Subtract" Modifiers="Control" Command="{Binding DiffPane.ZoomOutCommand}"/>
        <KeyBinding Key="D0"       Modifiers="Control" Command="{Binding DiffPane.ZoomResetCommand}"/>
        <KeyBinding Key="NumPad0"  Modifiers="Control" Command="{Binding DiffPane.ZoomResetCommand}"/>
    </Window.InputBindings>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" MinWidth="200"/>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="*" MinWidth="300"/>
        </Grid.ColumnDefinitions>

        <views:FileListView Grid.Column="0"
                            DataContext="{Binding FileList}"/>

        <GridSplitter Grid.Column="1"
                      Width="5"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      Background="#DDDDDD"/>

        <Border Grid.Column="2"
                Background="White">
            <views:DiffPaneView DataContext="{Binding DiffPane}"/>
        </Border>
    </Grid>
</Window>

