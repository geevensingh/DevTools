<Window x:Class="DiffViewer.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding Title}"
        SizeToContent="Height"
        Width="460"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="White">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{Binding Message}"
                   TextWrapping="Wrap"
                   FontSize="13"
                   Margin="0,0,0,16"/>

        <CheckBox x:Name="DontAskAgainCheck"
                  Grid.Row="1"
                  Content="Don't ask me again"
                  Margin="0,0,0,16"
                  Visibility="{Binding DontAskAgainVisibility}"/>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="ConfirmButton"
                    Content="{Binding ConfirmText}"
                    MinWidth="90"
                    Padding="12,4"
                    Margin="0,0,8,0"
                    Click="OnConfirm"
                    IsDefault="True"/>
            <Button x:Name="CancelButton"
                    Content="{Binding CancelText}"
                    MinWidth="90"
                    Padding="12,4"
                    Click="OnCancel"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
