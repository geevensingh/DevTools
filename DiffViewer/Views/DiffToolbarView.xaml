<UserControl x:Class="DiffViewer.Views.DiffToolbarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DiffViewer.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=vm:DiffPaneViewModel}"
             mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="ToolbarToggleStyle" TargetType="ToggleButton">
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="ToolbarButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#CCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
    </UserControl.Resources>

    <Border Background="#F8F8F8"
            BorderBrush="#DDD"
            BorderThickness="0,0,0,1"
            Padding="6,4">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <ToggleButton Style="{StaticResource ToolbarToggleStyle}"
                              IsChecked="{Binding IgnoreWhitespace}"
                              Content="Ignore WS"
                              ToolTip="Ignore whitespace differences (Ctrl+W)"/>
                <ToggleButton Style="{StaticResource ToolbarToggleStyle}"
                              IsChecked="{Binding ShowIntraLineDiff}"
                              Content="Intra-line"
                              ToolTip="Show word-level highlights inside modified lines (Ctrl+D)"/>
                <ToggleButton Style="{StaticResource ToolbarToggleStyle}"
                              IsChecked="{Binding IsSideBySide}"
                              Content="Side-by-side"
                              ToolTip="Toggle between side-by-side and inline diff layout (Ctrl+I)"/>
                <ToggleButton Style="{StaticResource ToolbarToggleStyle}"
                              IsChecked="{Binding ShowVisibleWhitespace}"
                              Content="Show WS"
                              ToolTip="Render spaces, tabs, and end-of-line markers (Ctrl+Shift+W)"/>

                <Separator Margin="6,2" Width="1" Background="#CCC"/>

                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding NavigatePreviousHunkCommand}"
                        Content="Prev"
                        ToolTip="Previous change (F7)"/>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding NavigateNextHunkCommand}"
                        Content="Next"
                        ToolTip="Next change (F8)"/>

                <Separator Margin="6,2" Width="1" Background="#CCC"/>

                <ToggleButton Style="{StaticResource ToolbarToggleStyle}"
                              IsChecked="{Binding LiveUpdates}"
                              IsEnabled="{Binding IsLiveUpdatesAvailable}"
                              Content="Live"
                              ToolTip="Auto-refresh when the working tree changes (Ctrl+L; greyed for commit-vs-commit)"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Command="{Binding DataContext.ShowSettingsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    Content="&#xE713;"
                    FontFamily="Segoe MDL2 Assets"
                    FontSize="14"
                    ToolTip="Settings (Ctrl+,)"/>
        </Grid>
    </Border>
</UserControl>
