<UserControl x:Class="DiffViewer.Views.RecentsBarView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:DiffViewer.ViewModels"
             d:DataContext="{d:DesignInstance Type=vm:RecentContextsViewModel}"
             mc:Ignorable="d">
    <!-- The whole bar collapses when there are no recent entries: bind
         Visibility to !IsEmpty via the existing inverse converter. -->
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsEmpty}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>

    <Border Padding="6,4"
            Background="#F5F5F5"
            BorderBrush="#DDDDDD"
            BorderThickness="0,0,0,1">
        <ComboBox ItemsSource="{Binding ItemViews}"
                  SelectedItem="{Binding SelectedItem, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                  IsEnabled="{Binding IsEnabled}"
                  AutomationProperties.Name="Recent contexts"
                  ToolTipService.ShowOnDisabled="True">
            <ComboBox.ItemTemplate>
                <DataTemplate DataType="{x:Type vm:RecentContextItem}">
                    <StackPanel Orientation="Vertical"
                                ToolTip="{Binding Tooltip}"
                                AutomationProperties.Name="{Binding AccessibilityName}">
                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Subtitle}"
                                   FontSize="10"
                                   Foreground="#888888"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
    </Border>
</UserControl>
