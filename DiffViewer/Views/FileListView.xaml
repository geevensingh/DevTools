<UserControl x:Class="DiffViewer.Views.FileListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DiffViewer.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=vm:FileListViewModel}"
             mc:Ignorable="d"
             Background="White">

    <UserControl.Resources>
        <SolidColorBrush x:Key="HeaderFgBrush"  Color="#424242"/>
        <SolidColorBrush x:Key="SectionBgBrush" Color="#F5F5F5"/>
        <SolidColorBrush x:Key="DimFgBrush"     Color="#909090"/>
        <SolidColorBrush x:Key="BadgeBgBrush"   Color="#E8E8E8"/>

        <!-- Style applied to ListBoxItem rows so virtualisation isn't broken
             by per-item content alignment overrides. -->
        <Style x:Key="EntryRowStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>

        <!-- Right-click context menu shared by every file row. The menu's
             DataContext is the FileEntryViewModel (because the row is the
             PlacementTarget). Commands live on MainViewModel - we walk up
             through the Window's DataContext via PlacementTarget.Tag, which
             we set to the row's ListBoxItem so the visual tree is rooted
             at a known anchor regardless of which presentation (flat or
             tree) the user is in. -->
        <ContextMenu x:Key="FileEntryContextMenu"
                     d:DataContext="{d:DesignInstance Type=vm:FileEntryViewModel}">
            <MenuItem Header="Show in Explorer"
                      Command="{Binding PlacementTarget.Tag.ShowInExplorerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}"
                      Visibility="{Binding ExistsOnDisk, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}"/>
            <MenuItem Header="Open with default app"
                      Command="{Binding PlacementTarget.Tag.OpenWithDefaultAppCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}"
                      Visibility="{Binding ExistsOnDisk, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}"/>
            <MenuItem Header="Open in external editor…"
                      Command="{Binding PlacementTarget.Tag.OpenInExternalEditorCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}">
                <MenuItem.Style>
                    <Style TargetType="MenuItem">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ExistsOnDisk}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ShouldHideOpenInExternalEditor}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </MenuItem.Style>
            </MenuItem>

            <Separator>
                <Separator.Visibility>
                    <Binding Path="IsUntracked" Converter="{x:Static vm:BoolToVisibilityConverter.Instance}"/>
                </Separator.Visibility>
            </Separator>
            <MenuItem Header="Stage file"
                      Command="{Binding PlacementTarget.Tag.StageFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}"
                      Visibility="{Binding IsUntracked, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}"/>
            <MenuItem Header="Delete file…"
                      Command="{Binding PlacementTarget.Tag.DeleteFileCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}"
                      Visibility="{Binding IsUntracked, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}"/>
            <MenuItem Header="Add to .gitignore"
                      Command="{Binding PlacementTarget.Tag.AddToGitignoreCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}"
                      Visibility="{Binding IsUntracked, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}"/>

            <Separator/>
            <MenuItem Header="Copy file name"
                      Command="{Binding PlacementTarget.Tag.CopyFileNameCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}"/>
            <MenuItem Header="Copy repo-relative path"
                      Command="{Binding PlacementTarget.Tag.CopyRepoRelativePathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}"/>
            <MenuItem Header="Copy full path"
                      Command="{Binding PlacementTarget.Tag.CopyFullPathCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}"/>

            <Separator/>
            <MenuItem Header="Copy blob SHA (left)"
                      Command="{Binding PlacementTarget.Tag.CopyLeftBlobShaCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}"
                      Visibility="{Binding HasLeftBlobSha, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}"/>
            <MenuItem Header="Copy blob SHA (right)"
                      Command="{Binding PlacementTarget.Tag.CopyRightBlobShaCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      CommandParameter="{Binding}"
                      Visibility="{Binding HasRightBlobSha, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}"/>

            <Separator/>
            <MenuItem Header="Refresh"
                      Command="{Binding PlacementTarget.Tag.RefreshListCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      InputGestureText="F5"/>
        </ContextMenu>

        <!-- Row template - shared by both the flat ListBox and the directory tree. -->
        <DataTemplate x:Key="EntryTemplate" DataType="{x:Type vm:FileEntryViewModel}">
            <Grid ContextMenu="{StaticResource FileEntryContextMenu}"
                  Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{StaticResource BadgeBgBrush}"
                        CornerRadius="3"
                        Padding="4,1"
                        Margin="0,0,6,0"
                        MinWidth="22">
                    <TextBlock Text="{Binding StatusBadge}"
                               FontFamily="Consolas"
                               FontWeight="SemiBold"
                               FontSize="11"
                               HorizontalAlignment="Center"/>
                </Border>

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsWhitespaceOnly}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource DimFgBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run Text="{Binding DisplayPath, Mode=OneWay}"/><Run Text="{Binding RenameDescriptor, Mode=OneWay}"
                                                                        Foreground="{StaticResource DimFgBrush}"/>
                </TextBlock>
            </Grid>
        </DataTemplate>

        <!-- Tree-view template - directory nodes show their label and recurse. -->
        <HierarchicalDataTemplate x:Key="DirectoryTemplate"
                                  DataType="{x:Type vm:DirectoryNodeViewModel}"
                                  ItemsSource="{Binding Children}">
            <TextBlock Text="{Binding Label}"
                       Foreground="{StaticResource HeaderFgBrush}"
                       FontWeight="SemiBold"/>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <DockPanel>
        <!-- Display-mode toggle bar -->
        <Border DockPanel.Dock="Top"
                Background="{StaticResource SectionBgBrush}"
                BorderBrush="#DDDDDD"
                BorderThickness="0,0,0,1"
                Padding="6">
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="Full path"
                             GroupName="DisplayMode"
                             Margin="0,0,8,0"
                             IsChecked="{Binding IsFullPathMode, Mode=TwoWay}"/>
                <RadioButton Content="Repo-relative"
                             GroupName="DisplayMode"
                             Margin="0,0,8,0"
                             IsChecked="{Binding IsRepoRelativeMode, Mode=TwoWay}"/>
                <RadioButton Content="Grouped by directory"
                             GroupName="DisplayMode"
                             IsChecked="{Binding IsGroupedByDirectoryMode, Mode=TwoWay}"/>
            </StackPanel>
        </Border>

        <!-- Two presentations stacked. Visibility flips based on display mode. -->
        <Grid>

            <!-- Flat-list mode: sections as Expanders, each containing a virtualised ListBox. -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Visibility="{Binding IsFlatMode, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}">
                <ItemsControl ItemsSource="{Binding Sections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FileListSectionViewModel}">
                            <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                      Margin="0,0,0,2">
                                <Expander.Header>
                                    <TextBlock>
                                        <Run Text="{Binding Header, Mode=OneWay}"
                                             FontWeight="Bold"
                                             Foreground="{StaticResource HeaderFgBrush}"/>
                                        <Run Text=" ("/>
                                        <Run Text="{Binding Entries.Count, Mode=OneWay}"/>
                                        <Run Text=")"/>
                                    </TextBlock>
                                </Expander.Header>
                                <ListBox ItemsSource="{Binding Entries}"
                                         BorderThickness="0"
                                         ItemTemplate="{StaticResource EntryTemplate}"
                                         ItemContainerStyle="{StaticResource EntryRowStyle}"
                                         VirtualizingStackPanel.IsVirtualizing="True"
                                         VirtualizingStackPanel.VirtualizationMode="Recycling"
                                         SelectedItem="{Binding DataContext.SelectedEntry,
                                                        RelativeSource={RelativeSource AncestorType=UserControl},
                                                        Mode=TwoWay}"/>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Grouped-by-directory mode: TreeView per section. -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Visibility="{Binding IsGroupedMode, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}">
                <ItemsControl ItemsSource="{Binding Sections}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:FileListSectionViewModel}">
                            <Expander IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                                      Margin="0,0,0,2">
                                <Expander.Header>
                                    <TextBlock>
                                        <Run Text="{Binding Header, Mode=OneWay}"
                                             FontWeight="Bold"
                                             Foreground="{StaticResource HeaderFgBrush}"/>
                                        <Run Text=" ("/>
                                        <Run Text="{Binding Entries.Count, Mode=OneWay}"/>
                                        <Run Text=")"/>
                                    </TextBlock>
                                </Expander.Header>
                                <TreeView ItemsSource="{Binding RootDirectories}"
                                          BorderThickness="0"
                                          VirtualizingStackPanel.IsVirtualizing="True"
                                          VirtualizingStackPanel.VirtualizationMode="Recycling">
                                    <TreeView.ItemContainerStyle>
                                        <Style TargetType="TreeViewItem">
                                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                        </Style>
                                    </TreeView.ItemContainerStyle>
                                    <TreeView.Resources>
                                        <HierarchicalDataTemplate DataType="{x:Type vm:DirectoryNodeViewModel}"
                                                                  ItemsSource="{Binding ChildrenAndFiles}">
                                            <TextBlock Text="{Binding Label}"
                                                       Foreground="{StaticResource HeaderFgBrush}"
                                                       FontWeight="SemiBold"/>
                                        </HierarchicalDataTemplate>
                                        <DataTemplate DataType="{x:Type vm:FileEntryViewModel}">
                                            <ContentPresenter Content="{Binding}"
                                                              ContentTemplate="{StaticResource EntryTemplate}"/>
                                        </DataTemplate>
                                    </TreeView.Resources>
                                </TreeView>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

        </Grid>
    </DockPanel>
</UserControl>
