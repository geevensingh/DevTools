<UserControl x:Class="DiffViewer.Views.DiffPaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:DiffViewer.ViewModels"
             xmlns:views="clr-namespace:DiffViewer.Views"
             xmlns:rendering="clr-namespace:DiffViewer.Rendering"
             xmlns:avalon="http://icsharpcode.net/sharpdevelop/avalonedit"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             d:DataContext="{d:DesignInstance Type=vm:DiffPaneViewModel}"
             mc:Ignorable="d"
             Background="White">

    <UserControl.Resources>
        <SolidColorBrush x:Key="EditorBgBrush"   Color="#FFFFFF"/>
        <SolidColorBrush x:Key="GutterBgBrush"   Color="#F5F5F5"/>
        <SolidColorBrush x:Key="PlaceholderFg"   Color="#666"/>
        <SolidColorBrush x:Key="DividerBrush"    Color="#DDDDDD"/>
        <SolidColorBrush x:Key="BannerBgBrush"   Color="#FFF8E1"/>
        <SolidColorBrush x:Key="BannerFgBrush"   Color="#5C4500"/>
        <SolidColorBrush x:Key="BannerBorder"    Color="#E8C46A"/>

        <!-- Right-click menu shared by all three AvalonEdit panes. The menu's
             Tag is set in the editor's ContextMenuOpening handler to a
             HunkActionContext (Side + OneBasedLine), which the items pick
             up via CommandParameter. Stage/Unstage/Revert hunk visibility
             keys off properties that the same handler refreshes on the
             pane VM, so they reflect the right-click target rather than
             the F7/F8 navigation cursor. -->
        <ContextMenu x:Key="DiffEditorContextMenu"
                     d:DataContext="{d:DesignInstance Type=vm:DiffPaneViewModel}">
            <MenuItem Header="Stage hunk"
                      Command="{Binding PlacementTarget.Tag.StageHunkAtCaretCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}, FallbackValue={x:Null}}"
                      CommandParameter="{Binding PlacementTarget.ContextMenu.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      Visibility="{Binding CanStageHunkAtCaret, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}"/>
            <MenuItem Header="Unstage hunk"
                      Command="{Binding PlacementTarget.Tag.UnstageHunkAtCaretCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}, FallbackValue={x:Null}}"
                      CommandParameter="{Binding PlacementTarget.ContextMenu.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      Visibility="{Binding CanUnstageHunkAtCaret, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}"/>
            <MenuItem Header="Revert hunk…"
                      Command="{Binding PlacementTarget.Tag.RevertHunkAtCaretCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}, FallbackValue={x:Null}}"
                      CommandParameter="{Binding PlacementTarget.ContextMenu.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                      Visibility="{Binding CanRevertHunkAtCaret, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}"/>
            <Separator Visibility="{Binding IsCaretInHunk, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}"/>
            <MenuItem Header="Copy"
                      Command="ApplicationCommands.Copy"
                      InputGestureText="Ctrl+C"/>
            <MenuItem Header="Select all"
                      Command="ApplicationCommands.SelectAll"
                      InputGestureText="Ctrl+A"/>
            <MenuItem Header="Find…"
                      Command="ApplicationCommands.Find"
                      InputGestureText="Ctrl+F"/>
        </ContextMenu>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <views:DiffToolbarView Grid.Row="0"/>

        <!-- Whitespace-only banner -->
        <Border Grid.Row="1"
                Background="{StaticResource BannerBgBrush}"
                BorderBrush="{StaticResource BannerBorder}"
                BorderThickness="0,0,0,1"
                Padding="12,6"
                Visibility="{Binding IsWhitespaceOnlyBannerVisible, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}">
            <TextBlock Foreground="{StaticResource BannerFgBrush}"
                       FontFamily="Segoe UI"
                       FontSize="12"
                       Text="Files differ only in whitespace. Ignore whitespace is on."/>
        </Border>

        <Grid Grid.Row="2">
            <!-- Side-by-side view (visible when no placeholder AND IsSideBySide=true) -->
            <Grid Visibility="{Binding ShowSideBySide, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="5"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <avalon:TextEditor x:Name="LeftEditor"
                                   Grid.Column="0"
                                   Document="{Binding LeftDocument, Mode=OneWay}"
                                   IsReadOnly="True"
                                   ShowLineNumbers="True"
                                   FontFamily="Consolas"
                                   FontSize="{Binding FontSize, Mode=OneWay}"
                                   WordWrap="False"
                                   Background="{StaticResource EditorBgBrush}"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto"
                                   ContextMenu="{StaticResource DiffEditorContextMenu}"
                                   ContextMenuOpening="OnLeftEditorContextMenuOpening"
                                   Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>

                <rendering:HunkOverviewBar Grid.Column="1"/>

                <GridSplitter Grid.Column="2"
                              Width="5"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              Background="{StaticResource DividerBrush}"/>

                <avalon:TextEditor x:Name="RightEditor"
                                   Grid.Column="3"
                                   Document="{Binding RightDocument, Mode=OneWay}"
                                   IsReadOnly="True"
                                   ShowLineNumbers="True"
                                   FontFamily="Consolas"
                                   FontSize="{Binding FontSize, Mode=OneWay}"
                                   WordWrap="False"
                                   Background="{StaticResource EditorBgBrush}"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto"
                                   ContextMenu="{StaticResource DiffEditorContextMenu}"
                                   ContextMenuOpening="OnRightEditorContextMenuOpening"
                                   Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>
            </Grid>

            <!-- Inline view (visible when no placeholder AND IsSideBySide=false) -->
            <Grid Visibility="{Binding ShowInline, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="32"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <rendering:HunkOverviewBar Grid.Column="0"/>

                <avalon:TextEditor x:Name="InlineEditor"
                                   Grid.Column="1"
                                   Document="{Binding InlineDocument, Mode=OneWay}"
                                   IsReadOnly="True"
                                   ShowLineNumbers="False"
                                   FontFamily="Consolas"
                                   FontSize="{Binding FontSize, Mode=OneWay}"
                                   WordWrap="False"
                                   Background="{StaticResource EditorBgBrush}"
                                   HorizontalScrollBarVisibility="Auto"
                                   VerticalScrollBarVisibility="Auto"
                                   ContextMenu="{StaticResource DiffEditorContextMenu}"
                                   ContextMenuOpening="OnInlineEditorContextMenuOpening"
                                   Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>
            </Grid>

            <!-- Placeholder view -->
            <Border Visibility="{Binding ShowPlaceholder, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}"
                    Background="White"
                    Padding="40">
                <TextBlock Text="{Binding PlaceholderMessage}"
                           Foreground="{StaticResource PlaceholderFg}"
                           FontFamily="Consolas"
                           FontSize="13"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Loading overlay -->
            <Border Visibility="{Binding IsLoading, Converter={x:Static vm:BoolToVisibilityConverter.Instance}}"
                    Background="#80FFFFFF"
                    IsHitTestVisible="False">
                <TextBlock Text="Loading..."
                           Foreground="#666"
                           FontFamily="Consolas"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>
